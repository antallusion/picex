{
  "name": "picex",
  "version": "1.0.0",
  "description": "Image extraction application - frontend and backend",
  "private": true,
  "scripts": {
    "start": "pnpm --filter frontend start",
    "dev": "pnpm --filter frontend start",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend start",
    "dev:all": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "build": "pnpm --filter backend build && pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
